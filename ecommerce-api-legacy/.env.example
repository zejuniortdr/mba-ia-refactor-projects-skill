# Configuração do servidor
PORT=3000

# Banco de dados (':memory:' usa SQLite em memória, recriado a cada boot)
DATABASE_FILE=:memory:

# Credenciais de banco — troque por valores reais em cada ambiente
DB_USER=troque-em-producao
DB_PASS=troque-por-senha-segura

# Gateway de pagamento — use a chave do ambiente (test/live) apropriada
PAYMENT_GATEWAY_KEY=pk_test_troque-por-chave-real

# SMTP
SMTP_USER=no-reply@exemplo.com
